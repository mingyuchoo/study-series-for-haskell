{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "903323050516555130"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "metadata": {
        "description": "azd 환경 이름. 리소스 이름 파생에 사용된다."
      }
    },
    "location": {
      "type": "string",
      "minLength": 1,
      "metadata": {
        "description": "모든 리소스의 기본 위치"
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "defaultValue": "blogadmin",
      "metadata": {
        "description": "PostgreSQL 관리자 로그인 이름"
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL 관리자 비밀번호. azd env set POSTGRES_ADMIN_PASSWORD <값> 으로 설정."
      }
    },
    "previewSecret": {
      "type": "securestring",
      "minLength": 16,
      "metadata": {
        "description": "서명 마스터 키(PREVIEW_SECRET). azd env set PREVIEW_SECRET <값> 으로 한 번 설정하면 azd 환경에 저장돼 재프로비저닝에도 고정된다(미설정 시 azd가 1회 입력을 요청). 값이 바뀌면 기존 세션·미리보기 토큰이 무효화됨."
      }
    },
    "developerIpAddress": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "개발자가 DB 에 직접 접속할 공인 IP. azd env set DEVELOPER_IP_ADDRESS <IP>. 비우면 방화벽에 개발자 규칙 없음."
      }
    },
    "entraAdminObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "PostgreSQL Entra 관리자 주체 objectId. azd env set ENTRA_ADMIN_OBJECT_ID <objectId>. 비우면 Entra 관리자 미생성."
      }
    },
    "entraAdminPrincipalName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Entra 관리자 주체 표시 이름(UPN/이메일 또는 그룹명)."
      }
    },
    "entraAdminPrincipalType": {
      "type": "string",
      "defaultValue": "User",
      "allowedValues": [
        "User",
        "Group",
        "ServicePrincipal"
      ],
      "metadata": {
        "description": "Entra 관리자 주체 유형."
      }
    },
    "principalId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "배포를 실행하는 주체의 objectId. azd 가 AZURE_PRINCIPAL_ID 환경값으로 자동 주입한다. RBAC 인증 Key Vault 에 시크릿을 쓰기 위한 데이터플레인 역할 부여에 사용된다."
      }
    },
    "principalType": {
      "type": "string",
      "defaultValue": "User",
      "allowedValues": [
        "User",
        "Group",
        "ServicePrincipal"
      ],
      "metadata": {
        "description": "배포 주체 유형. 로컬(az login)은 User, CI(OIDC)는 ServicePrincipal. azd env set AZURE_PRINCIPAL_TYPE ServicePrincipal 또는 워크플로 env 로 설정."
      }
    },
    "acsDataLocation": {
      "type": "string",
      "defaultValue": "United States",
      "metadata": {
        "description": "ACS(이메일) 데이터 저장 위치. azd env set ACS_DATA_LOCATION <값>. 예: United States, Europe, Asia Pacific."
      }
    },
    "customDomainName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "연결할 커스텀 도메인(apex). 예: mingyuchoo.com. 비우면 커스텀 도메인 비활성화. azd env set CUSTOM_DOMAIN_NAME mingyuchoo.com"
      }
    },
    "addCustomHostname": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "2단계 플래그. true 이면 인증서 없이 호스트네임만 바인딩한다(매니지드 인증서 발급의 전제 조건). DNS NS 위임/전파 완료 후 켤 것. azd env set ADD_CUSTOM_HOSTNAME true"
      }
    },
    "bindCustomDomain": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "3단계 플래그. true 이면 매니지드 인증서 발급 + SNI/TLS 바인딩까지 수행한다. 2단계(addCustomHostname)로 호스트네임 등록 후 켤 것. azd env set BIND_CUSTOM_DOMAIN true"
      }
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().id, parameters('environmentName'), parameters('location')))]",
    "tags": {
      "azd-env-name": "[parameters('environmentName')]"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[format('rg-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "resources",
      "resourceGroup": "[format('rg-{0}', parameters('environmentName'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "resourceToken": {
            "value": "[variables('resourceToken')]"
          },
          "tags": {
            "value": "[variables('tags')]"
          },
          "postgresAdminLogin": {
            "value": "[parameters('postgresAdminLogin')]"
          },
          "postgresAdminPassword": {
            "value": "[parameters('postgresAdminPassword')]"
          },
          "previewSecret": {
            "value": "[parameters('previewSecret')]"
          },
          "developerIpAddress": {
            "value": "[parameters('developerIpAddress')]"
          },
          "entraAdminObjectId": {
            "value": "[parameters('entraAdminObjectId')]"
          },
          "entraAdminPrincipalName": {
            "value": "[parameters('entraAdminPrincipalName')]"
          },
          "entraAdminPrincipalType": {
            "value": "[parameters('entraAdminPrincipalType')]"
          },
          "principalId": {
            "value": "[parameters('principalId')]"
          },
          "principalType": {
            "value": "[parameters('principalType')]"
          },
          "acsDataLocation": {
            "value": "[parameters('acsDataLocation')]"
          },
          "customDomainName": {
            "value": "[parameters('customDomainName')]"
          },
          "addCustomHostname": {
            "value": "[parameters('addCustomHostname')]"
          },
          "bindCustomDomain": {
            "value": "[parameters('bindCustomDomain')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.44.1.10279",
              "templateHash": "11061324079801741517"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "모든 리소스의 위치"
              }
            },
            "resourceToken": {
              "type": "string",
              "metadata": {
                "description": "리소스 이름을 전역 고유하게 만드는 토큰"
              }
            },
            "tags": {
              "type": "object",
              "metadata": {
                "description": "모든 리소스에 적용할 태그"
              }
            },
            "postgresAdminLogin": {
              "type": "string",
              "metadata": {
                "description": "PostgreSQL 관리자 로그인 이름"
              }
            },
            "postgresAdminPassword": {
              "type": "securestring",
              "metadata": {
                "description": "PostgreSQL 관리자 비밀번호"
              }
            },
            "developerIpAddress": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "개발자가 PostgreSQL 에 직접 접속하도록 허용할 공인 IP. 비우면 방화벽에 개발자 규칙을 만들지 않는다(앱만 접근). dev 환경에서만 설정 권장."
              }
            },
            "entraAdminObjectId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "PostgreSQL 에 Microsoft Entra 관리자로 등록할 주체의 objectId. 비우면 Entra 관리자를 만들지 않는다(비밀번호 인증만)."
              }
            },
            "entraAdminPrincipalName": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Entra 관리자 주체의 표시 이름(UPN/이메일 또는 그룹명). psql 접속 시 user 로 사용한다."
              }
            },
            "entraAdminPrincipalType": {
              "type": "string",
              "defaultValue": "User",
              "allowedValues": [
                "User",
                "Group",
                "ServicePrincipal"
              ],
              "metadata": {
                "description": "Entra 관리자 주체 유형."
              }
            },
            "principalId": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "배포를 실행하는 주체의 objectId(azd 가 AZURE_PRINCIPAL_ID 로 자동 주입). RBAC 인증 Key Vault 에 시크릿을 쓰려면 이 주체에 데이터플레인 역할이 필요하다(Contributor 만으로는 부족). 비우면 역할 할당을 건너뛴다."
              }
            },
            "principalType": {
              "type": "string",
              "defaultValue": "User",
              "allowedValues": [
                "User",
                "Group",
                "ServicePrincipal"
              ],
              "metadata": {
                "description": "배포 주체 유형. 로컬(az login)은 User, CI(OIDC)는 ServicePrincipal. 새로 만든 주체의 AAD 복제 지연으로 인한 역할 할당 실패를 줄인다."
              }
            },
            "webImage": {
              "type": "string",
              "defaultValue": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
              "metadata": {
                "description": "배포할 컨테이너 이미지. azd deploy가 실제 이미지를 푸시하기 전까지 사용하는 플레이스홀더."
              }
            },
            "acsDataLocation": {
              "type": "string",
              "defaultValue": "United States",
              "metadata": {
                "description": "ACS(이메일) 데이터 저장 위치(데이터 레지던시). 예: United States, Europe, Asia Pacific, Australia, UK."
              }
            },
            "previewSecret": {
              "type": "securestring",
              "defaultValue": "[newGuid()]",
              "metadata": {
                "description": "서명 마스터 키(PREVIEW_SECRET). main.bicep 이 azd 환경의 고정값을 전달한다. (모듈을 단독 배포할 때만 newGuid() 폴백이 동작하며, 그 경우 배포마다 값이 바뀜에 유의.)"
              }
            },
            "customDomainName": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "연결할 커스텀 도메인(apex). 예: mingyuchoo.com. 비우면 DNS Zone·커스텀 도메인 리소스를 만들지 않는다."
              }
            },
            "addCustomHostname": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "2단계 플래그. true 이면 인증서 없이 호스트네임만 바인딩한다(bindingType: Disabled). 매니지드 인증서를 발급하려면 호스트네임이 먼저 컨테이너 앱에 등록돼 있어야 하므로, 이 단계가 3단계(인증서 발급)의 전제 조건이다. DNS NS 위임/전파 완료 후 켤 것."
              }
            },
            "bindCustomDomain": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "3단계 플래그. true 이면 매니지드 인증서 발급 + SNI/TLS 바인딩까지 수행한다. 2단계(addCustomHostname)로 호스트네임이 이미 등록된 뒤에 켤 것(false 일 때는 DNS Zone·레코드만 생성)."
              }
            }
          },
          "variables": {
            "databaseName": "blog",
            "useCustomDomain": "[not(empty(parameters('customDomainName')))]",
            "doAddHostname": "[and(variables('useCustomDomain'), parameters('addCustomHostname'))]",
            "doBindCustomDomain": "[and(variables('useCustomDomain'), parameters('bindCustomDomain'))]",
            "wwwDomainName": "[format('www.{0}', parameters('customDomainName'))]",
            "customDomainsConfig": "[if(variables('doBindCustomDomain'), createArray(createObject('name', parameters('customDomainName'), 'bindingType', 'SniEnabled', 'certificateId', resourceId('Microsoft.App/managedEnvironments/managedCertificates', format('cae-{0}', parameters('resourceToken')), format('cert-apex-{0}', parameters('resourceToken')))), createObject('name', variables('wwwDomainName'), 'bindingType', 'SniEnabled', 'certificateId', resourceId('Microsoft.App/managedEnvironments/managedCertificates', format('cae-{0}', parameters('resourceToken')), format('cert-www-{0}', parameters('resourceToken'))))), if(variables('doAddHostname'), createArray(createObject('name', parameters('customDomainName'), 'bindingType', 'Disabled'), createObject('name', variables('wwwDomainName'), 'bindingType', 'Disabled')), createArray()))]"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[format('log-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "sku": {
                  "name": "PerGB2018"
                },
                "retentionInDays": 30
              }
            },
            {
              "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
              "apiVersion": "2023-01-31",
              "name": "[format('id-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]"
            },
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-11-01-preview",
              "name": "[format('cr{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": false
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', format('cr{0}', parameters('resourceToken')))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', format('cr{0}', parameters('resourceToken'))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', parameters('resourceToken'))), 'AcrPull')]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', parameters('resourceToken'))), '2023-01-31').principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('id-{0}', parameters('resourceToken')))]",
                "[resourceId('Microsoft.ContainerRegistry/registries', format('cr{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers",
              "apiVersion": "2024-08-01",
              "name": "[format('psql-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Standard_B1ms",
                "tier": "Burstable"
              },
              "properties": {
                "version": "16",
                "administratorLogin": "[parameters('postgresAdminLogin')]",
                "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
                "storage": {
                  "storageSizeGB": 32
                },
                "backup": {
                  "backupRetentionDays": 7,
                  "geoRedundantBackup": "Disabled"
                },
                "highAvailability": {
                  "mode": "Disabled"
                },
                "network": {
                  "publicNetworkAccess": "Enabled"
                },
                "authConfig": {
                  "activeDirectoryAuth": "Enabled",
                  "passwordAuth": "Enabled",
                  "tenantId": "[subscription().tenantId]"
                }
              }
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', format('psql-{0}', parameters('resourceToken')), variables('databaseName'))]",
              "properties": {
                "charset": "UTF8",
                "collation": "en_US.utf8"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('psql-{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', format('psql-{0}', parameters('resourceToken')), 'AllowAllAzureServices')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('psql-{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "condition": "[not(empty(parameters('developerIpAddress')))]",
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', format('psql-{0}', parameters('resourceToken')), 'AllowDeveloper')]",
              "properties": {
                "startIpAddress": "[parameters('developerIpAddress')]",
                "endIpAddress": "[parameters('developerIpAddress')]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('psql-{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "condition": "[not(empty(parameters('entraAdminObjectId')))]",
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/administrators",
              "apiVersion": "2024-08-01",
              "name": "[format('{0}/{1}', format('psql-{0}', parameters('resourceToken')), parameters('entraAdminObjectId'))]",
              "properties": {
                "principalType": "[parameters('entraAdminPrincipalType')]",
                "principalName": "[parameters('entraAdminPrincipalName')]",
                "tenantId": "[subscription().tenantId]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', format('psql-{0}', parameters('resourceToken')))]",
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/databases', format('psql-{0}', parameters('resourceToken')), variables('databaseName'))]"
              ]
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[format('cae-{0}', parameters('resourceToken'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "appLogsConfiguration": {
                  "destination": "log-analytics",
                  "logAnalyticsConfiguration": {
                    "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('resourceToken'))), '2023-09-01').customerId]",
                    "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('resourceToken'))), '2023-09-01').primarySharedKey]"
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', format('log-{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "type": "Microsoft.Communication/emailServices",
              "apiVersion": "2023-04-01",
              "name": "[format('acs-email-{0}', parameters('resourceToken'))]",
              "location": "global",
              "tags": "[parameters('tags')]",
              "properties": {
                "dataLocation": "[parameters('acsDataLocation')]"
              }
            },
            {
              "type": "Microsoft.Communication/emailServices/domains",
              "apiVersion": "2023-04-01",
              "name": "[format('{0}/{1}', format('acs-email-{0}', parameters('resourceToken')), 'AzureManagedDomain')]",
              "location": "global",
              "tags": "[parameters('tags')]",
              "properties": {
                "domainManagement": "AzureManaged",
                "userEngagementTracking": "Disabled"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Communication/emailServices', format('acs-email-{0}', parameters('resourceToken')))]"
              ]
            },
            {
              "type": "Microsoft.Communication/emailServices/domains/senderUsernames",
              "apiVersion": "2023-04-01",
              "name": "[format('{0}/{1}/{2}', format('acs-email-{0}', parameters('resourceToken')), 'AzureManagedDomain', 'donotreply')]",
              "properties": {
                "username": "donotreply",
                "displayName": "Haskell Blog"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Communication/emailServices/domains', format('acs-email-{0}', parameters('resourceToken')), 'AzureManagedDomain')]"
              ]
            },
            {
              "type": "Microsoft.Communication/communicationServices",
              "apiVersion": "2023-04-01",
              "name": "[format('acs-{0}', parameters('resourceToken'))]",
              "location": "global",
              "tags": "[parameters('tags')]",
              "properties": {
                "dataLocation": "[parameters('acsDataLocation')]",
                "linkedDomains": [
                  "[resourceId('Microsoft.Communication/emailServices/domains', format('acs-email-{0}', parameters('resourceToken')), 'AzureManagedDomain')]"
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Communication/emailServices/domains', format('acs-email-{0}', parameters('resourceToken')), 'AzureManagedDomain')]"
              ]
            },
            {
              "type": "Microsoft.KeyVault/vaults",
