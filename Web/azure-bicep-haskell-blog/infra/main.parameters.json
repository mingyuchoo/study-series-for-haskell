{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "postgresAdminLogin": {
      "value": "${POSTGRES_ADMIN_LOGIN=blogadmin}"
    },
    "postgresAdminPassword": {
      "value": "${POSTGRES_ADMIN_PASSWORD}"
    },
    "previewSecret": {
      "value": "${PREVIEW_SECRET}"
    },
    "developerIpAddress": {
      "value": "${DEVELOPER_IP_ADDRESS}"
    },
    "entraAdminObjectId": {
      "value": "${ENTRA_ADMIN_OBJECT_ID}"
    },
    "entraAdminPrincipalName": {
      "value": "${ENTRA_ADMIN_PRINCIPAL_NAME}"
    },
    "entraAdminPrincipalType": {
      "value": "${ENTRA_ADMIN_PRINCIPAL_TYPE=User}"
    },
    "acsDataLocation": {
      "value": "${ACS_DATA_LOCATION=United States}"
    },
    "customDomainName": {
      "value": "${CUSTOM_DOMAIN_NAME=}"
    },
    "addCustomHostname": {
      "value": "${ADD_CUSTOM_HOSTNAME=false}"
    },
    "bindCustomDomain": {
      "value": "${BIND_CUSTOM_DOMAIN=false}"
    }
  }
}
