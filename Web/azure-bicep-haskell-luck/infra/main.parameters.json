{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "postgresAdminLogin": {
      "value": "${POSTGRES_ADMIN_LOGIN=luckadmin}"
    },
    "postgresAdminPassword": {
      "value": "${POSTGRES_ADMIN_PASSWORD}"
    },
    "jwtSecret": {
      "value": "${JWT_SECRET}"
    },
    "allowedOrigins": {
      "value": "${ALLOWED_ORIGINS}"
    },
    "adminEmails": {
      "value": "${ADMIN_EMAILS}"
    },
    "developerIpAddress": {
      "value": "${DEVELOPER_IP_ADDRESS}"
    },
    "entraAdminObjectId": {
      "value": "${ENTRA_ADMIN_OBJECT_ID}"
    },
    "entraAdminPrincipalName": {
      "value": "${ENTRA_ADMIN_PRINCIPAL_NAME}"
    },
    "entraAdminPrincipalType": {
      "value": "${ENTRA_ADMIN_PRINCIPAL_TYPE=User}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "principalType": {
      "value": "${AZURE_PRINCIPAL_TYPE=User}"
    },
    "customDomainName": {
      "value": "${CUSTOM_DOMAIN_NAME=lucky.mingyuchoo.com}"
    },
    "addCustomHostname": {
      "value": "${ADD_CUSTOM_HOSTNAME=true}"
    },
    "bindCustomDomain": {
      "value": "${BIND_CUSTOM_DOMAIN=true}"
    }
  }
}
