# 백엔드 환경변수 (.env 로 복사해서 사용)

# 실행 모드: production 이면 아래 필수값 미설정 시 기동을 거부한다(fail-fast).
# 개발은 비워 두거나 development.
APP_ENV=development

# PostgreSQL 접속 문자열 (운영에서는 관리형 시크릿으로 주입 권장)
DATABASE_URL=postgresql://luck:luck@localhost:5432/luck

# JWT 서명 비밀키 — 운영에서는 반드시 길고 무작위한 값으로 교체.
#   생성 예: openssl rand -base64 48
# (미설정 시: 개발=경고 후 임시값 / 운영(APP_ENV=production)=기동 거부)
JWT_SECRET=

# CORS 허용 오리진 (콤마 구분). 비우면 모든 오리진 허용(개발용) — 운영에선 반드시 지정.
#   예: https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# 관리자 이메일 (콤마 구분). 지정하면 "첫 가입자=관리자" 규칙이 비활성화되어
# 권한 탈취 레이스를 막는다. 여기 적힌 이메일만 관리자가 된다(기동 시 자동 승격).
#   예: owner@example.com
ADMIN_EMAILS=

# 백엔드 포트
PORT=8080
